import java.util.*;

class TrieNode {
    Map<Character, TrieNode> children = new HashMap<>();
    Map<String, Integer> queries = new HashMap<>();
    boolean isEnd = false;
}

class AutocompleteSystem {

    private TrieNode root = new TrieNode();

    // Add query to system
    public void addQuery(String query, int frequency) {

        TrieNode node = root;

        for (char c : query.toCharArray()) {

            node.children.putIfAbsent(c, new TrieNode());
            node = node.children.get(c);

            node.queries.put(query,
                    node.queries.getOrDefault(query, 0) + frequency);
        }

        node.isEnd = true;
    }


    // Get top 10 suggestions
    public List<String> getSuggestions(String prefix) {

        TrieNode node = root;

        for (char c : prefix.toCharArray()) {

            if (!node.children.containsKey(c)) {
                return new ArrayList<>();
            }

            node = node.children.get(c);
        }

        // Min heap for top 10
        PriorityQueue<Map.Entry<String, Integer>> heap =
                new PriorityQueue<>(
                        (a, b) -> a.getValue() - b.getValue()
                );

        for (Map.Entry<String, Integer> entry : node.queries.entrySet()) {

            heap.offer(entry);

            if (heap.size() > 10) {
                heap.poll();
            }
        }

        List<String> result = new ArrayList<>();

        while (!heap.isEmpty()) {
            result.add(heap.poll().getKey());
        }

        Collections.reverse(result);

        return result;
    }


    // Update frequency when user searches
    public void search(String query) {

        addQuery(query, 1);
    }
}

public class Main {

    public static void main(String[] args) {

        AutocompleteSystem system = new AutocompleteSystem();

        system.addQuery("java tutorial", 120);
        system.addQuery("java interview questions", 90);
        system.addQuery("java hashmap example", 70);
        system.addQuery("javascript tutorial", 110);
        system.addQuery("java stream api", 60);

        Scanner sc = new Scanner(System.in);

        while (true) {

            System.out.print("Type prefix: ");

            String prefix = sc.nextLine();

            List<String> suggestions = system.getSuggestions(prefix);

            System.out.println("Suggestions:");

            for (String s : suggestions) {
                System.out.println(s);
            }

            System.out.println();
        }
    }
}
