import java.util.*;

class ParkingSpot {

    String licensePlate;
    long entryTime;
    boolean occupied;

    public ParkingSpot() {
        this.occupied = false;
    }
}

class ParkingLot {

    private ParkingSpot[] spots;
    private int capacity;
    private int occupiedCount = 0;

    public ParkingLot(int capacity) {

        this.capacity = capacity;
        spots = new ParkingSpot[capacity];

        for (int i = 0; i < capacity; i++) {
            spots[i] = new ParkingSpot();
        }
    }

    // Hash function based on license plate
    private int hash(String licensePlate) {

        return Math.abs(licensePlate.hashCode()) % capacity;
    }

    // Park vehicle
    public void parkVehicle(String licensePlate) {

        int index = hash(licensePlate);
        int startIndex = index;

        // Linear probing
        while (spots[index].occupied) {

            index = (index + 1) % capacity;

            if (index == startIndex) {
                System.out.println("Parking lot full!");
                return;
            }
        }

        spots[index].licensePlate = licensePlate;
        spots[index].entryTime = System.currentTimeMillis();
        spots[index].occupied = true;

        occupiedCount++;

        System.out.println("Vehicle " + licensePlate +
                " parked at spot " + index);
    }

    // Exit vehicle
    public void exitVehicle(String licensePlate) {

        int index = hash(licensePlate);
        int startIndex = index;

        while (spots[index].occupied) {

            if (spots[index].licensePlate.equals(licensePlate)) {

                long exitTime = System.currentTimeMillis();

                long parkedTime = exitTime - spots[index].entryTime;

                double hours = parkedTime / (1000.0 * 60 * 60);

                double bill = Math.max(1, hours) * 50;

                System.out.println("Vehicle " + licensePlate +
                        " leaving spot " + index);

                System.out.println("Parking bill: ₹" + bill);

                spots[index].occupied = false;
                spots[index].licensePlate = null;

                occupiedCount--;

                return;
            }

            index = (index + 1) % capacity;

            if (index == startIndex)
                break;
        }

        System.out.println("Vehicle not found!");
    }

    // Find nearest free spot
    public int findNearestSpot() {

        for (int i = 0; i < capacity; i++) {

            if (!spots[i].occupied)
                return i;
        }

        return -1;
    }

    // Parking statistics
    public void showStats() {

        double occupancyRate =
                (occupiedCount * 100.0) / capacity;

        System.out.println("\nParking Statistics");

        System.out.println("Total Spots: " + capacity);
        System.out.println("Occupied Spots: " + occupiedCount);
        System.out.println("Occupancy Rate: "
                + String.format("%.2f", occupancyRate) + "%");
    }
}

public class Main {

    public static void main(String[] args) throws InterruptedException {

        ParkingLot lot = new ParkingLot(10);

        lot.parkVehicle("TN01AB1234");
        lot.parkVehicle("TN09CD5678");
        lot.parkVehicle("TN11XY9999");

        Thread.sleep(2000);

        lot.exitVehicle("TN01AB1234");

        System.out.println("Nearest free spot: " +
                lot.findNearestSpot());

        lot.showStats();
    }
}
